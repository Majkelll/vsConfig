{
  // lens
  "gitlens.currentLine.enabled": false,

  // theme
  "workbench.colorTheme": "One Dark Pro Darker",

  // auto open current file
  "explorer.autoReveal": true,
  "dotnet.automaticallySyncWithActiveItem": true,

  // vim
  "vim.leader": " ",
  "keyboard.dispatch": "keyCode",
  "vim.useSystemClipboard": true,
  "editor.selectionClipboard": false,
  "vim.handleKeys": {
    "<C-p>": false
  },

  // autosave
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 500,

  // vim keybinding
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["H"],
      "commands": ["workbench.action.previousEditor"]
    },
    {
      "before": ["L"],
      "commands": ["workbench.action.nextEditor"]
    },
    {
      "before": ["g", "e"],
      "commands": ["editor.action.marker.next"]
    },
    {
      "before": ["g", "E"],
      "commands": ["editor.action.marker.nextInFiles"]
    },
    {
      "before": ["g", "a"],
      "commands": ["editor.action.quickFix"]
    },
    {
      "before": ["<leader>", "o"],
      "commands": ["workbench.action.closeOtherEditors"]
    },
    {
      "before": ["<leader>", "p"],
      "commands": ["workbench.action.pinEditor"]
    }
  ],

  //layout
  "workbench.editor.pinnedTabsOnSeparateRow": true,
  "editor.minimap.enabled": false,

  // plugins
  // - resharper
  "resharper.region.region": "Europe",
  "resharper.dataSharing.allowDataSharing": false,

  // random
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "cSpell.userWords": [
    "Antiforgery",
    "blazor",
    "Hsts",
    "localdeploy",
    "rendermode",
    "stylesheet"
  ],
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    "*.cs": "${capture}.designer.cs,${capture}.g.cs,${capture}.generated.cs,${capture}.run.json,${capture}.settings.json,${capture}.settings.*.json",
    "*.csproj": "${capture}.csproj.user",
    "*.json": "${capture}.Development.json",
    "*.cshtml": "${capture}.cshtml.cs,${capture}.cshtml.css",
    "*.razor": "${capture}.razor.cs,${capture}.razor.css",
    "*.resx": "${capture}.Designer.cs",
    "*.xaml": "${capture}.xaml.cs",
    "*.sqlite": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*"
  },
}